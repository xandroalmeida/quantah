# Exemplo do env usado pelos testes E2E (Laravel Dusk — ADR-008).
# Copie para `.env.dusk.local` (gitignored) ajustando os valores reais.
# O `make e2e` / o setup local geram esse arquivo automaticamente a partir do `.env`.
#
# A ideia: o Dusk sobe um Chrome real (via Selenium) que abre a app pela REDE do Docker,
# então a APP_URL é o hostname do serviço (`laravel.test`), não `localhost`.

APP_ENV=local
APP_URL=http://laravel.test

# Selenium standalone-chromium (serviço do compose). Em execução local via Sail.
DUSK_DRIVER_URL=http://selenium:4444/wd/hub

# Demais variáveis são herdadas do `.env` (APP_KEY, DB_*, etc.) ao gerar o `.env.dusk.local`.

# Login com Google (STORY-022): driver simulado nos E2E — sem credencial real.
GOOGLE_FAKE=true
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
